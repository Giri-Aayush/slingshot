<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleExecutable</key>
	<string>Slingshot</string>
	<key>CFBundleIdentifier</key>
	<string>com.aayush.slingshot</string>
	<key>CFBundleName</key>
	<string>Slingshot</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>1.5</string>
	<key>CFBundleVersion</key>
	<string>16</string>
	<key>LSMinimumSystemVersion</key>
	<string>13.0</string>
	<key>LSUIElement</key>
	<true/>
	<key>NSBonjourServices</key>
	<array>
		<string>_slingshot._tcp</string>
		<string>_slingshot._udp</string>
	</array>
	<key>NSCameraUsageDescription</key>
	<string>Slingshot watches for your hand gestures, and in Normal mode checks that the catchers face matches the grabbers.</string>
	<key>NSLocalNetworkUsageDescription</key>
	<string>Slingshot finds nearby Macs running Slingshot to beam your screenshot to.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Slingshot listens for a finger snap to wake the camera and to copy screenshots to your clipboard. Audio never leaves your Mac.</string>
</dict>
</plist>
